<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- App Header with Icon and Title inside a Toolbar-like layout -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:minHeight="72dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_heart"
                    android:contentDescription="App Icon" />

                <TextView
                    android:id="@+id/appTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wellness Pulse Monitor"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginStart="20dp" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Full content below the toolbar -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Health Metrics Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:elevation="6dp"
                android:backgroundTint="#FAFAFA"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/heartRateValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heart Rate: -- BPM"
                        android:textSize="20sp"
                        android:textColor="#D32F2F"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/stepsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Steps: --"
                        android:textSize="20sp"
                        android:textColor="#388E3C"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/sleepValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sleep: -- hrs"
                        android:textSize="20sp"
                        android:textColor="#1976D2"
                        android:layout_marginBottom="10dp" />

                    <TextView
                        android:id="@+id/moodValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mood: Neutral"
                        android:textSize="18sp"
                        android:textColor="#616161"
                        android:layout_marginBottom="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mood Control Buttons -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                android:elevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp">

                    <Button
                        android:id="@+id/happyButton"
                        android:layout_width="73dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="😊 Happy" />

                    <Button
                        android:id="@+id/angryButton"
                        android:layout_width="74dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="😠 Angry" />

                    <Button
                        android:id="@+id/neutralButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="😐 Neutral" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actions: Walk / Run / Pause -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                android:elevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp">

                    <Button
                        android:id="@+id/walkButton"
                        android:layout_width="73dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="🚶 Walk" />

                    <Button
                        android:id="@+id/runButton"
                        android:layout_width="63dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="🏃 Run" />

                    <Button
                        android:id="@+id/pauseButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="⏸️ Pause" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Speed Modes -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                android:elevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp">

                    <Button
                        android:id="@+id/speed1xButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1x Speed"
                        android:layout_margin="8dp" />

                    <Button
                        android:id="@+id/speed2xButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2x Speed"
                        android:layout_margin="8dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sleep Control -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                android:elevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp">

                    <Button
                        android:id="@+id/startSleep"
                        android:layout_width="88dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="🛌 Start Sleep" />

                    <Button
                        android:id="@+id/endSleep"
                        android:layout_width="72dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="8dp"
                        android:text="⏰ End Sleep" />

                    <Button
                        android:id="@+id/plus3hrSleep"
                        android:layout_width="88dp"
                        android:layout_height="wrap_content"
                        android:text="+3hr Sleep" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Reset Buttons -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="12dp"
                android:elevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="12dp">

                    <Button
                        android:id="@+id/resetSteps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔁 Reset Steps"
                        android:layout_margin="8dp" />

                    <Button
                        android:id="@+id/resetSleep"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔁 Reset Sleep"
                        android:layout_margin="8dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
